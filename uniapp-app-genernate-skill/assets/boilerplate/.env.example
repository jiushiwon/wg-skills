# Pexels API Key
# 从 https://www.pexels.com/api/ 获取
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# 接口 baseURL
# 微信小程序：需配置为 request 合法域名
VITE_BASE_URL=https://api.example.com

# H5 接口 baseURL（开发时可能需要代理或处理 CORS）
VITE_H5_BASE_URL=https://api.example.com

# App 接口 baseURL
VITE_APP_BASE_URL=https://api.example.com
